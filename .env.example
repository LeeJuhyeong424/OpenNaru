# ══ 앱 설정 ══
APP_ENV=development
APP_SECRET_KEY=change-this-secret-key-minimum-32-chars
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ══ 데이터베이스 ══
DATABASE_URL=postgresql://wiki_user:wiki_password@localhost:5432/opennaru

# ══ JWT ══
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ══ CORS ══
CORS_ORIGINS=["http://localhost:3000"]
